{
  "template_id": "profitability_trend",
  "description": "盈利趋势因子：用基本面数据的趋势变化预测横截面收益",
  "skeleton": "group_rank(ts_rank({numerator} / {denominator}, {window}), {group})",
  "field_pairs": [
    {"numerator": "operating_income", "denominator": "equity"},
    {"numerator": "ebit", "denominator": "equity"},
    {"numerator": "operating_income", "denominator": "sales"},
    {"numerator": "ebit", "denominator": "sales"},
    {"numerator": "free_cash_flow_reported_value", "denominator": "equity"},
    {"numerator": "free_cash_flow_reported_value", "denominator": "sales"},
    {"numerator": "ebitda", "denominator": "equity"},
    {"numerator": "ebitda", "denominator": "sales"},
    {"numerator": "retained_earnings", "denominator": "equity"},
